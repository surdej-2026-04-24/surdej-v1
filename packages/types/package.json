{
    "name": "@surdej/types",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./contracts/*": {
            "types": "./dist/contracts/*.d.ts"
        }
    },
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "typescript": "^5.9.0-beta"
    }
}