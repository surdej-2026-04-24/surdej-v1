{
    "name": "@surdej/module-member-example-worker",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "prisma": {
        "schema": "prisma/schema/member_example.prisma"
    },
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc -p tsconfig.json",
        "start": "node dist/server.js",
        "typecheck": "tsc --noEmit",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev --name",
        "db:push": "prisma db push",
        "db:studio": "prisma studio"
    },
    "dependencies": {
        "fastify": "^5.3.3",
        "@fastify/cors": "^11.0.1",
        "@prisma/client": "^6.19.2",
        "nats": "^2.29.3",
        "zod": "^3.25.0",
        "@surdej/module-member-example-shared": "workspace:*"
    },
    "devDependencies": {
        "@types/node": "^22.15.0",
        "prisma": "^6.19.2",
        "tsx": "^4.19.4",
        "typescript": "^5.9.0-beta"
    }
}