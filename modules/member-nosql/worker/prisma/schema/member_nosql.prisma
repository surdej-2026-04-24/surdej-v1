generator client {
    provider        = "prisma-client-js"
    output          = "../../node_modules/.prisma/member-nosql-client"
    previewFeatures = ["multiSchema"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
    schemas  = ["member_nosql"]
}

// ─── Collection ────────────────────────────────────────────────
// Organises documents into named buckets with optional hierarchy.
// A null parentId means a root-level collection.

model NosqlCollection {
    id          String    @id @default(uuid())
    tenantId    String
    name        String
    slug        String
    description String?   @db.Text
    parentId    String?

    // JSON Schema for optional data validation (stored as JSONB)
    schema      Json?

    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    deletedAt   DateTime?
    createdBy   String?
    updatedBy   String?

    parent      NosqlCollection?  @relation("SubCollections", fields: [parentId], references: [id])
    children    NosqlCollection[] @relation("SubCollections")
    documents   NosqlDocument[]

    @@unique([tenantId, parentId, slug])
    @@index([tenantId])
    @@index([parentId])
    @@schema("member_nosql")
}

// ─── Document ──────────────────────────────────────────────────
// One big JSONB document table with metadata fields.
// Soft-delete via deletedAt; version counter increments on update.

model NosqlDocument {
    id           String    @id @default(uuid())
    tenantId     String
    collectionId String
    data         Json
    version      Int       @default(1)

    createdAt    DateTime  @default(now())
    updatedAt    DateTime  @updatedAt
    deletedAt    DateTime?
    createdBy    String?
    updatedBy    String?

    collection   NosqlCollection      @relation(fields: [collectionId], references: [id])
    versions     NosqlDocumentVersion[]

    @@index([tenantId])
    @@index([collectionId])
    @@index([deletedAt])
    @@schema("member_nosql")
}

// ─── Document Version ──────────────────────────────────────────
// Immutable snapshot of document.data taken before each update.

model NosqlDocumentVersion {
    id         String   @id @default(uuid())
    documentId String
    version    Int
    data       Json

    createdAt  DateTime @default(now())
    createdBy  String?

    document   NosqlDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

    @@unique([documentId, version])
    @@index([documentId])
    @@schema("member_nosql")
}
