{
    "name": "@surdej/module-tool-management-tools-worker",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "start": "tsx --env-file=.env src/server.ts",
        "build": "tsc",
        "db:generate": "prisma generate --schema=prisma/schema/tool_management_tools.prisma",
        "db:migrate": "prisma migrate dev --schema=prisma/schema/tool_management_tools.prisma",
        "db:push": "prisma db push --schema=prisma/schema/tool_management_tools.prisma",
        "db:seed": "tsx --env-file=.env prisma/seed.ts",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@ai-sdk/azure": "^2.0.0",
        "@ai-sdk/openai": "^2.0.0",
        "@fastify/cors": "^10.0.0",
        "@fastify/multipart": "^9.0.0",
        "@prisma/client": "^6.0.0",
        "@surdej/module-tool-management-tools-shared": "workspace:*",
        "ai": "latest",
        "fastify": "^5.0.0",
        "nats": "^2.28.0",
        "zod": "^3.23.0"
    },
    "devDependencies": {
        "prisma": "^6.0.0",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0",
        "vitest": "^3.0.0"
    }
}
