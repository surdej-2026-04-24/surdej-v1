{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "composite": true,
        "outDir": "dist-node",
        "declaration": true
    },
    "include": [
        "vite.config.ts",
        "plugins"
    ]
}