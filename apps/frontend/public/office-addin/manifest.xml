<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:type="TaskPaneApp">
    <Id>surdej-office-bridge</Id>
    <Version>1.0.0</Version>
    <ProviderName>Surdej</ProviderName>
    <DefaultLocale>da-DK</DefaultLocale>
    <DisplayName DefaultValue="Surdej Bridge" />
    <Description DefaultValue="2-way AI bridge between Office documents and Surdej" />
    <IconUrl DefaultValue="https://your-domain.pages.dev/surdej-icon-32.png" />
    <HighResolutionIconUrl DefaultValue="https://your-domain.pages.dev/surdej-icon-64.png" />
    <SupportUrl DefaultValue="https://your-domain.pages.dev/help" />

    <Hosts>
        <Host Name="Document" />     <!-- Word -->
        <Host Name="Workbook" />     <!-- Excel -->
        <Host Name="Presentation" /> <!-- PowerPoint -->
    </Hosts>

    <DefaultSettings>
        <!-- Points to the frontend route, NOT a separate app -->
        <SourceLocation DefaultValue="https://your-domain.pages.dev/office-addin" />
    </DefaultSettings>

    <Permissions>ReadWriteDocument</Permissions>

    <Requirements>
        <Sets>
            <Set Name="SharedRuntime" MinVersion="1.1" />
        </Sets>
    </Requirements>
</OfficeApp>
