{
    "name": "@surdej/api",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc -p tsconfig.build.json",
        "start": "node dist/server.js",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:push": "prisma db push",
        "db:seed": "tsx prisma/seed.ts",
        "db:studio": "prisma studio",
        "cli:login": "tsx src/cli.ts login",
        "cli:logout": "tsx src/cli.ts logout",
        "cli:whoami": "tsx src/cli.ts whoami"
    },
    "dependencies": {
        "@ai-sdk/azure": "^3.0.30",
        "@ai-sdk/openai": "^3.0.29",
        "@aws-sdk/client-s3": "^3.992.0",
        "@aws-sdk/lib-storage": "^3.992.0",
        "@azure/storage-blob": "^12.31.0",
        "@fastify/cors": "^11.0.1",
        "@fastify/multipart": "^9.4.0",
        "@prisma/client": "^6.9.0",
        "@simplewebauthn/server": "^13.3.0",
        "@surdej/core": "workspace:*",
        "@tavily/core": "^0.7.1",
        "@types/pdf-parse": "^1.1.5",
        "ai": "^6.0.86",
        "bcryptjs": "^3.0.2",
        "fastify": "^5.3.3",
        "fastify-metrics": "^13.2.0",
        "ioredis": "^5.9.3",
        "jsonwebtoken": "^9.0.2",
        "jwks-rsa": "^3.2.0",
        "nats": "^2.29.3",
        "otpauth": "^9.5.0",
        "pdf-parse": "^2.4.5",
        "pino": "^9.7.0",
        "pino-pretty": "^13.0.0",
        "qrcode": "^1.5.4",
        "yaml": "^2.8.2",
        "zod": "^3.25.17"
    },
    "devDependencies": {
        "@simplewebauthn/types": "^12.0.0",
        "@types/bcryptjs": "^3.0.0",
        "@types/dotenv": "^8.2.3",
        "@types/jsonwebtoken": "^9.0.9",
        "@types/qrcode": "^1.5.6",
        "@types/sharp": "^0.32.0",
        "dotenv": "^17.3.1",
        "prisma": "^6.9.0",
        "tsx": "^4.19.4",
        "typescript": "^5.9.0-beta",
        "vitest": "^3.2.1"
    },
    "prisma": {
        "schema": "prisma/schema/schema.prisma",
        "seed": "tsx prisma/seed.ts"
    },
    "optionalDependencies": {
        "sharp": "^0.34.5"
    }
}