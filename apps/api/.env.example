# ──────────────────────────────────────────────────
# Surdej API — Environment Variables
# ──────────────────────────────────────────────────
#
# ⚠️  These values are set in docker-compose.yml.
#     This file serves as DOCUMENTATION ONLY.
#
# The API always runs in Docker. The frontend on the
# host connects to http://localhost:5001.
#
# For external/production endpoints, override in the
# deployment environment (Azure, k8s, etc).
# ──────────────────────────────────────────────────

# Database (Docker-internal: postgres:5432)
DATABASE_URL="postgresql://surdej:surdej_dev@postgres:5432/surdej?schema=public"

# Server
PORT=5001
HOST=0.0.0.0
NODE_ENV=development

# Auth (entra | demo | none)
AUTH_PROVIDER=demo

# JWT (for Entra ID production)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=

# NATS (Docker-internal: nats:4222)
NATS_URL=nats://nats:4222

# CORS (frontend dev server)
CORS_ORIGIN=http://localhost:6001
