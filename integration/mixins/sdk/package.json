{
  "name": "@surdej/mixin-sdk",
  "version": "0.1.0",
  "description": "SDK for building iframe mixin tools that integrate with the Surdej platform",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_ORG/surdej-v1.git",
    "directory": "integration/mixins/sdk"
  },
  "license": "MIT",
  "keywords": [
    "surdej",
    "mixin",
    "iframe",
    "sdk",
    "postmessage"
  ],
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  }
}
